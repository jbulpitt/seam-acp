# --- Discord ---
DISCORD_BOT_TOKEN=
# Comma-separated list of Discord user IDs allowed to control the bot.
# Single user: DISCORD_ALLOWED_USER_IDS=123456789
# Multiple users: DISCORD_ALLOWED_USER_IDS=123456789,987654321
DISCORD_ALLOWED_USER_IDS=
# Optional: register slash commands instantly to a single guild for development.
DISCORD_DEV_GUILD_ID=

# --- Storage / sandbox ---
# Root folder containing repos the agent is allowed to work in.
REPOS_ROOT=/Users/you/Projects
# Comma-separated extra absolute directories that `/seam attach` and the
# fence-as-file shortcut may read from. REPOS_ROOT is always allowed.
# ATTACH_ROOTS=/Users/you/Downloads,/Users/you/Documents
# Where to store sqlite + per-session data.
DATA_DIR=./data

# --- Agent ---
# Which agent profile to use by default. Currently: "copilot".
DEFAULT_AGENT=copilot
# Default model id (e.g. gpt-5.4, claude-sonnet-4.5, claude-opus-4.7, auto).
DEFAULT_MODEL=gpt-5.4
# Optional explicit path to the copilot CLI; defaults to "copilot" on PATH.
COPILOT_CLI_PATH=
# Register additional Copilot profiles, each with its own --config-dir
# (= its own auth, MCP config, session history). Format:
#   id1:/abs/path/to/dir1,id2:/abs/path/to/dir2
# Each becomes an agent profile named `copilot-<id>` selectable in
# /seam agent. Run `COPILOT_HOME=<dir> copilot login` once per profile.
# COPILOT_PROFILES=work:/Users/you/.copilot-work,personal:/Users/you/.copilot-personal
# Optional explicit path to the gemini CLI; defaults to "gemini" on PATH.
GEMINI_CLI_PATH=
# Default model for the Gemini profile (overrides DEFAULT_MODEL when
# DEFAULT_AGENT=gemini or when a session picks gemini).
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# --- Anthropic Claude (optional) ---
# Install the adapter: npm i -g @anthropic-ai/claude-code @agentclientprotocol/claude-agent-acp
# Then: claude /login
# Optional explicit path to claude-agent-acp; defaults to "claude-agent-acp" on PATH.
CLAUDE_CLI_PATH=
# Default model for the Claude profile.
CLAUDE_DEFAULT_MODEL=claude-sonnet-4.5
# Register additional Claude profiles, each with its own CLAUDE_CONFIG_DIR
# (= its own auth + settings). Format mirrors COPILOT_PROFILES:
#   id1:/abs/path/to/dir1,id2:/abs/path/to/dir2
# Each becomes an agent profile named `claude-<id>` selectable in /seam agent.
# Run `CLAUDE_CONFIG_DIR=<dir> claude /login` once per profile.
# CLAUDE_PROFILES=work:/Users/you/.claude-work,personal:/Users/you/.claude-personal

# --- Behavior ---
TURN_TIMEOUT_SECONDS=900
LOG_LEVEL=info
HEALTH_PORT=3000
# Bot-wide default permission policy for new sessions.
# - always: auto-approve every request (yolo)
# - ask:    post a Discord prompt with buttons; deny on 5-min timeout (recommended)
# - deny:   auto-deny everything
# Override per-session with /seam approve <always|ask|deny>.
DEFAULT_PERMISSION_POLICY=ask
# Deprecated. When true, forces the bot-wide default to "always".
DEFAULT_AUTO_APPROVE=false

# --- MCP servers (global, applied to every session) ---
# Playwright: gives the agent a real Chromium browser. Useful for
# screenshots and web tasks; emitted images flow back as Discord
# attachments via the agent-file pipeline.
# Requires Chromium (~150 MB), auto-downloaded by Playwright on first run.
MCP_PLAYWRIGHT_ENABLED=false

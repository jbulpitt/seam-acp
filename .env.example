# --- Discord ---
DISCORD_BOT_TOKEN=
# Comma-separated list of Discord user IDs allowed to control the bot.
# Single user: DISCORD_ALLOWED_USER_IDS=123456789
# Multiple users: DISCORD_ALLOWED_USER_IDS=123456789,987654321
DISCORD_ALLOWED_USER_IDS=
# Optional: register slash commands instantly to a single guild for development.
DISCORD_DEV_GUILD_ID=

# --- Storage / sandbox ---
# Root folder containing repos the agent is allowed to work in.
REPOS_ROOT=/Users/you/Projects
# Where to store sqlite + per-session data.
DATA_DIR=./data

# --- Agent ---
# Which agent profile to use by default. Currently: "copilot".
DEFAULT_AGENT=copilot
# Default model id (e.g. gpt-5.4, claude-sonnet-4.5, claude-opus-4.7, auto).
DEFAULT_MODEL=gpt-5.4
# Optional explicit path to the copilot CLI; defaults to "copilot" on PATH.
COPILOT_CLI_PATH=

# --- Behavior ---
TURN_TIMEOUT_SECONDS=900
LOG_LEVEL=info
HEALTH_PORT=3000
# Set to true to auto-approve all agent permission requests (shell exec, writes, etc.).
# Leave false (the default) — the agent will be denied any permission request it makes.
# Override per-session with /seam approve always|ask.
DEFAULT_AUTO_APPROVE=false

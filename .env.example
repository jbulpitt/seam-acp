# --- Discord ---
DISCORD_BOT_TOKEN=
# Set to your Discord user ID; only this user can control the bot.
DISCORD_OWNER_USER_ID=
# Optional: register slash commands instantly to a single guild for development.
DISCORD_DEV_GUILD_ID=

# --- Storage / sandbox ---
# Root folder containing repos the agent is allowed to work in.
REPOS_ROOT=/Users/you/Projects
# Where to store sqlite + per-session data.
DATA_DIR=./data

# --- Agent ---
# Which agent profile to use by default. Currently: "copilot".
DEFAULT_AGENT=copilot
# Default model id (e.g. gpt-5.4, claude-sonnet-4.5, claude-opus-4.7, auto).
DEFAULT_MODEL=gpt-5.4
# Optional explicit path to the copilot CLI; defaults to "copilot" on PATH.
COPILOT_CLI_PATH=

# --- Behavior ---
TURN_TIMEOUT_SECONDS=900
LOG_LEVEL=info
HEALTH_PORT=3000

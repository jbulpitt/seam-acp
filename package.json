{
  "name": "seam-acp",
  "version": "0.1.0",
  "private": false,
  "description": "A chat-platform bridge to ACP-compatible coding agents (Copilot, Claude Code, ...). Discord today, Slack tomorrow.",
  "author": "Jesse Bulpitt <jbulpitt>",
  "license": "MIT",
  "homepage": "https://github.com/jbulpitt/seam-acp",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbulpitt/seam-acp.git"
  },
  "bugs": {
    "url": "https://github.com/jbulpitt/seam-acp/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "redeploy": "npm run build && (sleep 10 && pm2 restart seam-acp &) && echo 'Build complete — restarting in 10s'",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
